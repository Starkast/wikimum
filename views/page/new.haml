%h1.title Skapa ny sida

%form{ method: :post }
  %input{ type: :hidden, name: 'authenticity_token', value: csrf_token }
  %label.block{ for: 'title' } Titel
  %input#title{ type: :text, name: 'title', maxlength: 74, size: 50, value: @page.title, autofocus: true }

  %label.block{ for: 'page-content' }
    Innehåll
    != haml :'_link_titles', layout: false
  %textarea#page-content{ name: 'content', cols: 84, rows: 20 }= @page.content

  %label.block{ for: 'comment' } Kommentar
  %input#comment{ type: :text, name: 'comment', maxlength: 74, size: 50, value: @page.comment }

  %label.block Synlighet
  - if starkast?
    %div
      %label
        %input{ type: :radio, name: 'visibility', value: 'concealed', checked: @page.concealed? }
        Privat
  %div
    %label
      %input{ type: :radio, name: 'visibility', value: 'public', checked: !@page.concealed? && !@page.crawlable? }
      Publik
  %div
    %label
      %input{ type: :radio, name: 'visibility', value: 'crawlable', checked: @page.crawlable? }
      Publik, tillåt sökmotorer

  %p{ style: "margin-top: 1em;" }
    %button Skapa sida
    eller
    %a{ href: '/list' } Avbryt

  %hr

  %label.block{ for: 'description' } Sidbeskrivning
  %textarea#description{ name: 'description', cols: 50, rows: 3 }= @page.description
